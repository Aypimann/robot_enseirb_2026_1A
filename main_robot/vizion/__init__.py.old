import cam_to_2D_coners as cam_t2
import from_2D_to_3D as f2t3
import pos_from_3Dtags as pft
from pixel7a_cam_prop import *

fix_arcuo_size = 100. # milimeters
fix_tags = [0]
#fix_tags = [1, 2]
nut_arucos_size = 40.

expected_cam_ry = 0.
expected_cam_rx = 0.
expected_cam_z = 0.

cam_ry_tolerance = 100.
cam_rx_tolerance = 100.
cam_z_tolerance = 1.0e8

pos = 0., 0.
rot = 0.

print("!! camera setting are the defaut rear pixel 7a one !!")
print("!! expected cam angle is unset !!")
print("!! fix tags are wrong !!")

fix_th_pos = {
    (0, 0) : (-50.,-50., 0.),
    (0, 1) : ( 50.,-50., 0.),
    (0, 2) : (-50., 50., 0.),
    (0, 3) : ( 50., 50., 0.)
}
"""
fix_th_pos = {
    (2,0) : (-127.5,-42.5, 0.),
    (2,1) : ( -42.5,-42.5, 0.),
    (2,2) : (-127.5, 42.5, 0.),
    (2,3) : ( -42.5, 42.5, 0.),

    (1,0) : (  42.5, 42.5, 0.),
    (1,1) : ( 127.5,-42.5, 0.),
    (1,2) : (  42.5,-42.5, 0.),
    (1,3) : ( 127.5, 42.5, 0.)
}
"""


def update_tags():
    cam_t2.capture_frame()
    cam_t2.find_tags()
    cam_t2.tags = (
        [correct_image_deform(t) for t in cam_t2.tags[0]],
        cam_t2.tags[1]
    )

def update_pos_cam_looks_ok(rx, ry, rz, x, y, z):
    global pos, rot
    if abs(expected_cam_ry - ry) > cam_ry_tolerance:
        return
    if abs(expected_cam_rx - rx) > cam_rx_tolerance:
        return
    if abs(expected_cam_z - z) > cam_z_tolerance:
        return
    rot = rz
    pos = x, y

def process_tags():
    fix_obs_pos = {}
    for corners, tag_id in zip(cam_t2.tags[0], cam_t2.tags[1]):
        print("tag id:", tag_id)
        if tag_id in fix_tags:
            Xc = f2t3.im_coordonate_to_unscaled(
                corners, center, pixel_per_radian)
            print("X_c:",Xc)
            PX = f2t3.project_on_tag(*Xc, fix_arcuo_size)
            print(f"deteced fix tag {tag_id} at 3D {PX}")
            for i in range(4):
                fix_obs_pos[(tag_id, i)] = PX[i]
    if len(fix_obs_pos) != 0:
        for key in fix_obs_pos:
            pft.add_th_point(*fix_th_pos[key])
            pft.add_obs_point(*fix_obs_pos[key])
            print("add_th_point",*fix_th_pos[key])
            print("add_obs_point",*fix_obs_pos[key])
        pos = pft.compute()
        print("pos:", pos)
        pft.flush_th_point()
        pft.flush_obs_point()
        update_pos_cam_looks_ok(*pos)

if __name__ == "__main__":
    import os
    path = os.getcwd() + "/im1.jpg"
    from time import time
    t0 = time()
    cam_t2.import_frame_from_file(path)
    cam_t2.find_tags()
    process_tags()
    print("time:", time()-t0)

