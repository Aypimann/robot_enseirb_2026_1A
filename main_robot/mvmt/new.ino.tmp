#include <Arduino.h>
#include "FastAccelStepper.h"

// Pinout des Moteurs
#define STEP_PIN_L 16
#define DIR_PIN_L  4
#define STEP_PIN_R 5
#define DIR_PIN_R  17

// Pinout des Capteurs Ultra-son
#define TRIG_PIN  23
#define ECHO_PIN_1 35
#define ECHO_PIN_2 34
#define ECHO_PIN_3 39
#define ECHO_PIN_4 36

// Pinout du Capteur de Couleur
#define OUT 18
#define S2 19
#define S3 21

// Pinout du L298N
#define EN_MOTEUR_PINCE 13
#define IN1_MOTEUR_PINCE 14
#define IN2_MOTEUR_PINCE 27
#define IN1_PISTON 26
#define IN2_PISTON 25

// Pinout du Moteurs des Pinces
#define C1_MOTEUR_PINCE 33
#define C2_MOTEUR_PINCE 32

// Pinout du Bouton
#define BOUTON 22

// Pinout du Servomoteur
#define SERVOMOTEUR 15

// Variables pour les Capteurs Ultra-son
const int echoPins[] = {ECHO_PIN_1, ECHO_PIN_2, ECHO_PIN_3, ECHO_PIN_4}; // 0,1: pulseIn | 2,3: AnalogpulseIn
const int SEUIL_LOGIQUE = 2000;
const float DISTANCE_CRITIQUE = 20.0;

// Filtrage et Validation 
int compteurObstacle = 0;          // Compteur d'itérations
const int SEUIL_VALIDATION = 5;    // Nombre de mesures consécutives sous la limite

FastAccelStepperEngine engine = FastAccelStepperEngine();
FastAccelStepper *leftStepper = NULL;
FastAccelStepper *rightStepper = NULL;

// --- Variables de contrôle ---
float distances[4] = {100.0, 100.0, 100.0, 100.0};

/**
 * @brief Fonction pour lire la distance d'un capteur ultra-son 
 * @param index Variable pour choisir un capteur parmi les 4
 */
float readDistance(int index) 
{
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  unsigned long duration = 0;
  if (index < 2) 
  {
    duration = pulseIn(echoPins[index], HIGH, 25000);
  } else 
  {
    unsigned long startM = micros();
    while (analogRead(echoPins[index]) < SEUIL_LOGIQUE) 
    {
    if (micros() - startM > 20000) return 0;
    }
    unsigned long pStart = micros();
    while (analogRead(echoPins[index]) >= SEUIL_LOGIQUE) 
    {
      if (micros() - pStart > 25000) break;
    }
    duration = micros() - pStart;
  }
  return (duration * 0.0343) / 2.0;
}

void setup() {
    Serial.begin(115200);
    pinMode(TRIG_PIN, OUTPUT);
    for(int i = 0; i < 4; i++) pinMode(echoPins[i], INPUT);

    // Initialisation des moteurs
    engine.init();
    leftStepper = engine.stepperConnectToPin(STEP_PIN_L);
    rightStepper = engine.stepperConnectToPin(STEP_PIN_R);

    if (leftStepper && rightStepper) {
        leftStepper->setDirectionPin(-DIR_PIN_L);
        rightStepper->setDirectionPin(DIR_PIN_R);
        
        leftStepper->setAcceleration(1000);
        rightStepper->setAcceleration(1000);
        
        leftStepper->setSpeedInHz(5000); // Vitesse de croisière
        rightStepper->setSpeedInHz(5000);
    }
}

void loop() {
    bool lectureAlerte = false;
    leftStepper->runForward();
    rightStepper->runForward();

    // 1. Vérification des capteurs
    for (int i = 0; i < 4; i++) {
        float d = readDistance(i);
        // Si l'un des capteurs voit un objet (ignorer le 0 qui est souvent une erreur)
        if (d > 2.0 && d < DISTANCE_CRITIQUE) {
            lectureAlerte = true;
            break; // Pas besoin de vérifier les autres si un seul voit un danger
        }
    }

    // 2. Logique de confirmation (Debounce)
    if (lectureAlerte) {
        compteurObstacle++;
        Serial.print("Alerte ! Confirmation en cours : ");
        Serial.println(compteurObstacle);
    } else {
        // Si le chemin est libre, on réinitialise le compteur immédiatement
        compteurObstacle = 0;
    }
    
    // 3. Action sur les moteurs
    if (compteurObstacle >= SEUIL_VALIDATION) {
        // L'obstacle est confirmé par 5 mesures successives
        if (leftStepper->isRunning()) {
            Serial.println("!!! OBSTACLE CONFIRMÉ : ARRÊT !!!");
            leftStepper->stopMove();
            rightStepper->stopMove();
        }
    } else {
        // Soit le compteur est à 0, soit on n'a pas encore atteint 5
        // On permet au robot d'avancer ou de continuer sa route
        if (!leftStepper->isRunning() && compteurObstacle == 0) {
            leftStepper->runForward();
            rightStepper->runForward();
        }
    }
    delay(30); // Fréquence d'échantillonnage
}
